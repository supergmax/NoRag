# Backend à utiliser : sqlite (local) ou supabase
NORAG_BACKEND=sqlite

# Clé API Google Gemini (obligatoire)
GEMINI_API_KEY=your-gemini-api-key

# Chemin de la base SQLite (optionnel, défaut: NoRag/local/norag.db)
SQLITE_DB_PATH=local/norag.db

# Credentials Supabase (requis uniquement si NORAG_BACKEND=supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
